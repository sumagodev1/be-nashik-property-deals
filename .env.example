NODE_ENV=development
PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=nashik_property_deals
DB_CONNECTION_LIMIT=10

JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-with-different-long-random-string
JWT_REFRESH_TTL=7d

SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Nasik Property Deals <noreply@example.com>"
ADMIN_NOTIFICATION_EMAIL=admin@example.com

CORS_ORIGIN=http://localhost:5173

UPLOAD_PUBLIC_DIR=uploads/public
UPLOAD_PRIVATE_DIR=uploads/private
UPLOAD_MAX_FILE_BYTES=1048576
UPLOAD_TOTAL_QUOTA_BYTES=524288000

OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_PER_MINUTE=1
OTP_RATE_PER_HOUR=5

# Cron token for the cPanel-cron-callable email outbox endpoint.
# Generate a random ≥32-char value and use it in your cron entry, e.g.:
#   */10 * * * * curl -fsS -X POST -H "X-Cron-Token: $TOKEN" https://your-host/api/cron/email-outbox/process
CRON_TOKEN=replace-with-random-32-plus-chars
